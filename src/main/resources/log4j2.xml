<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN" packages="be.unamur.snail.logging">
    <Appenders>
        <ProgressBarAwareConsole name="Console">
            <PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg"/>
        </ProgressBarAwareConsole>
    </Appenders>
    <Loggers>
        <Root level="${sys:log.level:-INFO}">
            <AppenderRef ref="Console"/>
        </Root>
    </Loggers>
</Configuration>
